# Binaries
build/
*.exe
*.out
*.test
.air/
.air-worker/
.air-worker-rabbitmq/
.air-worker-kafka/

# Keys — NEVER commit private keys
keys/
*.pem

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code — personal/machine-local settings, not project config
.claude/settings.local.json

# TypeScript incremental build cache
*.tsbuildinfo

# Test & coverage
coverage.out
coverage.html
*.coverprofile

# OS
.DS_Store
Thumbs.db

# Go workspace
vendor/
go.sum   # track this normally; listed here as reminder to review

# Swagger generated
# Swagger generated files (large JSON/YAML) — not committed
# EXCEPTION: docs.go stub IS committed so the package exists for compilation
docs/swagger/*.json
docs/swagger/*.yaml
docs/swagger/swagger.json
docs/swagger/swagger.yaml

# Logs
*.log

# ── Email templates ────────────────────────────────────────────────────────────
email-templates/node_modules/
email-templates/dist-ts/
# Keep stub dist files so Go compiles without npm
# Real compiled versions are generated by: make build-emails
# pkg/email/dist/ is tracked (stubs committed)
