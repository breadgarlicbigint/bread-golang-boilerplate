# App
APP_NAME=bread-golang-boilerplate
APP_ENV=development          # development | staging | production
APP_PORT=3000
APP_VERSION=1.0.0
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:5173 # frontend base URL used to build links in outbound emails (web/ test client)

# Database - MongoDB
# ID strategy for MongoDB _id fields: uuid (default) or objectid
# See docs/id-migration.md to switch strategies
MONGO_ID_TYPE=uuid

# Database - MongoDB
MONGO_URI=mongodb://mongo1:27017,mongo2:27017,mongo3:27017/?replicaSet=rs0
MONGO_DB_NAME=bread_boilerplate
MONGO_POOL_MIN=2
MONGO_POOL_MAX=10
MONGO_TIMEOUT=10s

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# JWT
# Generate with: openssl ecparam -genkey -name prime256v1 -noout | openssl pkcs8 -topk8 -nocrypt -out keys/access_private.pem
# Then: openssl ec -in keys/access_private.pem -pubout -out keys/access_public.pem
JWT_ACCESS_PRIVATE_KEY_PATH=./keys/access_private.pem
JWT_ACCESS_PUBLIC_KEY_PATH=./keys/access_public.pem
JWT_ACCESS_EXPIRE=15m

# Generate with: openssl ecparam -genkey -name secp521r1 -noout | openssl pkcs8 -topk8 -nocrypt -out keys/refresh_private.pem
# Then: openssl ec -in keys/refresh_private.pem -pubout -out keys/refresh_public.pem
JWT_REFRESH_PRIVATE_KEY_PATH=./keys/refresh_private.pem
JWT_REFRESH_PUBLIC_KEY_PATH=./keys/refresh_public.pem
JWT_REFRESH_EXPIRE=168h # 7 days — Go's time.ParseDuration has no "d" unit, so this must stay in h/m/s

# Session
SESSION_SECRET=super-secret-session-key-change-in-production
SESSION_EXPIRE=7d

# Auth
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_MAX_PASSWORD_ATTEMPTS=5
AUTH_LOCKOUT_DURATION=15m

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=1m

# API Key
API_KEY_HEADER=X-Api-Key
API_KEY_PREFIX=bread

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS S3
AWS_S3_BUCKET=
AWS_S3_PRESIGN_EXPIRE=15m
AWS_S3_BASE_URL=

# AWS SES
AWS_SES_FROM_EMAIL=no-reply@example.com
AWS_SES_FROM_NAME=Bread Boilerplate

# Email delivery: "ses" (default, uses AWS_* + AWS_SES_* above) or "smtp" (uses SMTP_* below)
MAIL_DRIVER=smtp

# SMTP (only used when MAIL_DRIVER=smtp)
# Personal Gmail accounts must use smtp.gmail.com (NOT smtp.google.com, which is
# the Workspace relay and rejects personal accounts + app passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=breadgarlic.dev@gmail.com
SMTP_PASSWORD=lcsvsshfvgyucuuj
SMTP_FROM_EMAIL=breadgarlic.dev@gmail.com
SMTP_FROM_NAME=Api

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3000/v1/auth/google/callback

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Queue backend the API enqueues jobs onto by default. MUST match a worker
# you actually run:
#   redis    → apps/worker           (make docker-worker)   — default
#   rabbitmq → apps/worker-rabbitmq   (make docker-rabbitmq)
#   kafka    → apps/worker-kafka      (make docker-kafka)
# A mismatch = jobs published to a broker nobody consumes → emails never send.
QUEUE_DRIVER=redis

# Optional: route specific workloads to a DIFFERENT driver than QUEUE_DRIVER
# above, so e.g. reliability-sensitive transactional email (welcome/verify/
# reset/OTP) rides RabbitMQ while high-volume promotional/broadcast email
# rides Kafka. Leave blank to fall back to QUEUE_DRIVER (today's single-
# backend behavior). The worker process for EVERY driver referenced here
# must be running too — see "Background Job Queue Backends" in CLAUDE.md.
#   QUEUE_TRANSACTIONAL_DRIVER=rabbitmq
#   QUEUE_PROMOTIONAL_DRIVER=kafka
QUEUE_TRANSACTIONAL_DRIVER=rabbitmq
QUEUE_PROMOTIONAL_DRIVER=kafka

# Worker (Asynq / Redis)
WORKER_CONCURRENCY=10
WORKER_QUEUES=default:6,critical:3,low:1

# Worker (RabbitMQ) — used by apps/worker-rabbitmq (pkg/queue/rabbitmq)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=bread.tasks
RABBITMQ_QUEUE=bread.worker
RABBITMQ_PREFETCH=10

# Worker (Kafka) — used by apps/worker-kafka (pkg/queue/kafka)
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=bread.tasks
KAFKA_GROUP_ID=bread.worker

# MQTT (pkg/mqtt, modules/iot) — unrelated to QUEUE_DRIVER above; this is the
# device-telemetry demo's own broker, not a task-queue backend. Blank
# (default) disables it entirely — modules/iot's routes stay registered but
# every call returns 503 "MQTT broker is not configured". Set this to use
# `make docker-mqtt` (starts an Eclipse Mosquitto broker alongside the API):
#   MQTT_BROKER_URL=tcp://mosquitto:1883
MQTT_BROKER_URL=
MQTT_CLIENT_ID=bread-api
MQTT_USERNAME=
MQTT_PASSWORD=

# Monitoring (Prometheus + Grafana) — no config needed here. GET /metrics is
# always exposed by the API (like /health); `make docker-monitoring` starts
# Prometheus (scrapes it) + Grafana (pre-provisioned dashboard) alongside the
# stack. See "Monitoring (Prometheus / Grafana)" in CLAUDE.md.

# ── NEW FEATURES ──────────────────────────────────────────────────────────────

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:3000/v1/auth/github/callback

# WebAuthn / Passkey
# RP_ORIGIN must match the origin of the page that calls navigator.credentials.*.
# That's the web/ test client (Vite dev server), not the API itself.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:5173
WEBAUTHN_RP_NAME=Bread Boilerplate

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=+15551234567
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886

# Multi-Tenant
MULTI_TENANT_ENABLED=false
BASE_DOMAIN=localhost

# App Versioning
APP_VERSION_CHECK_ENABLED=true

# Firebase (Push Notifications)
FIREBASE_CREDENTIALS_FILE=./keys/firebase-service-account.json

# i18n
DEFAULT_LANG=en
LOCALES_DIR=./locales

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./keys/apple_private.p8

# Notification
NOTIFICATION_ENABLED=true
